rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Regla global: Permitir todo a usuarios autenticados
    // (Incluye collection "reservas", "master_data", etc.)
    match /{document=**} {
      // PERMITIR ACCESO PÚBLICO TEMPORAL (v5)
      // Útil para desarrollo local con file:// donde Auth falla
      allow read, write: if true;
    }
  }
}
